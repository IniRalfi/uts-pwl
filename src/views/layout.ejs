<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <link href="/css/output.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">
  <script src="https://unpkg.com/@phosphor-icons/web"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    body {
      font-family: 'Inter', sans-serif;
    }

    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    ::-webkit-scrollbar-thumb {
      background: #93c5fd;
      border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #60a5fa;
    }
  </style>
</head>

<body class="bg-gray-50 text-gray-800 antialiased selection:bg-blue-200">
  <div class="flex h-screen overflow-hidden">

    <!-- SIDEBAR BIRU (Sesuai Mau Dosen) -->
    <aside id="sidebar"
      class="bg-blue-700 text-white w-72 flex flex-col absolute z-50 inset-y-0 left-0 transform -translate-x-full md:relative md:translate-x-0 transition-transform duration-300 ease-in-out shadow-2xl md:shadow-none">

      <div class="flex items-center justify-center h-20 border-b border-blue-600 mt-2">
        <div class="flex items-center gap-3">
          <div
            class="w-10 h-10 bg-blue-900 rounded-xl flex items-center justify-center text-white shadow-lg shadow-blue-900/30">
            <i class="ph-bold ph-student text-2xl"></i>
          </div>
          <h2 class="text-2xl font-extrabold text-white tracking-tight">Akademik<span class="text-blue-300">Pro</span>
          </h2>
        </div>
      </div>

      <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">

        <!-- Path Indicator -->
        <div class="px-3 mb-6">
          <div
            class="bg-blue-900/50 border border-blue-500 text-blue-200 text-[11px] font-mono px-3 py-2 rounded-lg flex items-center gap-2 shadow-inner">
            <i class="ph ph-terminal-window text-sm"></i>
            <span class="truncate opacity-90">PATH: <span class="font-bold text-white">
                <%= currentPath %>
              </span></span>
          </div>
        </div>

        <p class="text-xs font-semibold text-blue-200 uppercase tracking-wider mb-4 px-3">Menu Utama</p>

        <!-- Dashboard Link -->
        <a href="/"
          class="flex items-center gap-3 px-3 py-3 rounded-xl transition-all duration-200 <%= currentPath === '/' ? 'bg-blue-900 text-white shadow-md font-medium' : 'hover:bg-blue-600 text-blue-100 hover:text-white' %>">
          <i class="ph <%= currentPath === '/' ? 'ph-squares-four-fill' : 'ph-squares-four' %> text-xl"></i>
          <span>Dashboard</span>
        </a>

        <!-- Master Data Link -->
        <div class="mt-2 text-sm">
          <button onclick="toggleMenu()"
            class="w-full flex items-center justify-between px-3 py-3 rounded-xl transition-all duration-200 hover:bg-blue-600 text-blue-100 hover:text-white">
            <div class="flex items-center gap-3">
              <i class="ph ph-database text-xl"></i>
              <span class="text-base">Data Master</span>
            </div>
            <i id="master-chevron"
              class="ph ph-caret-down transition-transform duration-300 <%= currentPath.includes('/mahasiswa') ? 'rotate-180' : '' %>"></i>
          </button>

          <div id="submenu" class="<%= currentPath.includes('/mahasiswa') ? '' : 'hidden' %> mt-2 space-y-1">
            <a href="/mahasiswa"
              class="flex items-center gap-3 pl-11 pr-3 py-2.5 rounded-xl transition-all duration-200 <%= currentPath.includes('/mahasiswa') ? 'bg-blue-900 text-white shadow-md font-medium' : 'text-blue-200 hover:bg-blue-600 hover:text-white' %>">
              <i
                class="ph <%= currentPath.includes('/mahasiswa') ? 'ph-users-three-fill' : 'ph-users-three' %> text-lg"></i>
              <span>Mahasiswa</span>
            </a>
          </div>
        </div>
      </nav>

      <div class="p-4 border-t border-blue-600">
        <div class="bg-blue-800 p-4 rounded-xl flex items-center justify-center gap-3 border border-blue-600">
          <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse shadow-[0_0_8px_rgba(74,222,128,0.8)]"></div>
          <span class="text-xs font-medium text-blue-100">Server Online : 3000</span>
        </div>
      </div>
    </aside>

    <div id="mobile-overlay"
      class="hidden fixed inset-0 z-40 bg-gray-900/50 backdrop-blur-sm transition-opacity md:hidden"
      onclick="toggleSidebar()"></div>

    <div class="flex-1 flex flex-col min-w-0">
      <header
        class="bg-white/70 backdrop-blur-md border-b border-gray-200 h-20 flex items-center justify-between px-6 sticky top-0 z-30">
        <div class="flex items-center gap-4">
          <button class="md:hidden text-gray-500 hover:text-blue-600 transition-colors p-2 rounded-lg bg-gray-100"
            onclick="toggleSidebar()">
            <i class="ph ph-list text-2xl"></i>
          </button>
          <h1 class="font-bold text-xl text-gray-800 hidden sm:block">
            <%= title %>
          </h1>
        </div>

        <div class="flex items-center gap-4">
          <button
            class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-500 hover:bg-gray-200 hover:text-blue-600 transition-all relative">
            <i class="ph ph-bell text-xl"></i>
            <span class="absolute top-2 right-2.5 w-2 h-2 bg-red-500 rounded-full border border-white"></span>
          </button>
          <div class="w-px h-8 bg-gray-200"></div>
          <div class="relative">
            <button onclick="toggleProfile()" class="flex items-center gap-3 focus:outline-none group">
              <div class="text-right hidden sm:block">
                <p class="text-sm font-semibold text-gray-700">Hi, Admin</p>
                <p class="text-xs text-gray-500 group-hover:text-blue-500 transition-colors">Developer</p>
              </div>
              <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Rafli&backgroundColor=eff6ff" alt="Avatar"
                class="w-10 h-10 rounded-full border-2 border-blue-100 shadow-sm object-cover">
              <i class="ph ph-caret-down text-gray-400 text-xs"></i>
            </button>
            <div id="profileMenu"
              class="hidden absolute right-0 mt-3 w-48 bg-white border border-gray-100 shadow-xl rounded-xl overflow-hidden origin-top-right transition-all">
              <div class="px-4 py-3 border-b border-gray-50 bg-gray-50/50">
                <p class="text-sm font-medium text-gray-900">Signed in as</p>
                <p class="text-xs text-gray-500 truncate">admin@kampus.ac.id</p>
              </div>
              <div class="py-1">
                <a href="#" class="flex items-center gap-2 px-4 py-2 text-sm text-red-600 hover:bg-red-50">
                  <i class="ph ph-sign-out"></i> Log Out
                </a>
              </div>
            </div>
          </div>
        </div>
      </header>

      <main class="p-6 sm:p-8 flex-1 overflow-y-auto">
        <%- body %>
      </main>
    </div>
  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('-translate-x-full');
      document.getElementById('mobile-overlay').classList.toggle('hidden');
    }
    function toggleMenu() {
      document.getElementById('submenu').classList.toggle('hidden');
      document.getElementById('master-chevron').classList.toggle('rotate-180');
    }
    function toggleProfile() { document.getElementById('profileMenu').classList.toggle('hidden'); }
    document.addEventListener('click', function (event) {
      const profileMenu = document.getElementById('profileMenu');
      if (profileMenu && !profileMenu.previousElementSibling.contains(event.target) && !profileMenu.contains(event.target)) {
        profileMenu.classList.add('hidden');
      }
    });
  </script>
</body>

</html>