<div class="mb-8">
    <h2 class="text-3xl font-extrabold text-gray-800 tracking-tight">Dashboard Overview</h2>
    <p class="text-gray-500 text-sm mt-1">Selamat datang kembali! Berikut adalah ringkasan data akademik saat ini ✨</p>
</div>

<!-- Card Overview -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
    <!-- Card Mahasiswa -->
    <div
        class="bg-gradient-to-br from-blue-500 to-blue-700 p-6 rounded-2xl shadow-lg transform transition duration-300 hover:-translate-y-2 hover:shadow-2xl relative overflow-hidden group">
        <div
            class="absolute -right-4 -bottom-4 opacity-20 text-8xl transform transition duration-300 group-hover:scale-110 group-hover:rotate-12">
            🎓</div>
        <div class="relative z-10">
            <h3 class="text-blue-100 text-sm font-semibold uppercase tracking-wider mb-2">Total Mahasiswa</h3>
            <div class="flex items-end gap-2">
                <p class="text-5xl font-black text-white drop-shadow-md">
                    <%= total_mahasiswa %>
                </p>
                <p class="text-blue-200 mb-1 font-medium">Orang</p>
            </div>
        </div>
    </div>

    <!-- Card Dosen -->
    <div
        class="bg-gradient-to-br from-green-500 to-green-700 p-6 rounded-2xl shadow-lg transform transition duration-300 hover:-translate-y-2 hover:shadow-2xl relative overflow-hidden group">
        <div
            class="absolute -right-4 -bottom-4 opacity-20 text-8xl transform transition duration-300 group-hover:scale-110 group-hover:rotate-12">
            👨‍🏫</div>
        <div class="relative z-10">
            <h3 class="text-green-100 text-sm font-semibold uppercase tracking-wider mb-2">Total Dosen</h3>
            <div class="flex items-end gap-2">
                <p class="text-5xl font-black text-white drop-shadow-md">35</p>
                <p class="text-green-200 mb-1 font-medium">Orang</p>
            </div>
        </div>
    </div>

    <!-- Card Matkul -->
    <div
        class="bg-gradient-to-br from-purple-500 to-purple-700 p-6 rounded-2xl shadow-lg transform transition duration-300 hover:-translate-y-2 hover:shadow-2xl relative overflow-hidden group">
        <div
            class="absolute -right-4 -bottom-4 opacity-20 text-8xl transform transition duration-300 group-hover:scale-110 group-hover:rotate-12">
            📚</div>
        <div class="relative z-10">
            <h3 class="text-purple-100 text-sm font-semibold uppercase tracking-wider mb-2">Total Mata Kuliah</h3>
            <div class="flex items-end gap-2">
                <p class="text-5xl font-black text-white drop-shadow-md">50</p>
                <p class="text-purple-200 mb-1 font-medium">Kelas</p>
            </div>
        </div>
    </div>
</div>

<!-- List Mahasiswa Terbaru -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-6">
    <div class="px-6 py-5 border-b border-slate-200 flex justify-between items-center bg-slate-50/50">
        <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
            <i class="ph-fill ph-users-three text-indigo-600"></i>
            Data Mahasiswa Terbaru
        </h3>
        <!-- Link pergi ke halaman data lengkap -->
        <a href="/mahasiswa"
            class="text-sm font-medium text-indigo-600 hover:text-indigo-700 hover:underline transition-colors">
            Kelola Semua Data &rarr;
        </a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse whitespace-nowrap">
            <thead>
                <tr class="bg-white border-b border-slate-200 text-slate-500 text-sm">
                    <th class="py-4 px-6 font-semibold w-16 text-center">No</th>
                    <th class="py-4 px-6 font-semibold">NIM</th>
                    <th class="py-4 px-6 font-semibold">Nama Lengkap</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if(mahasiswa && mahasiswa.length> 0) { %>
                    <% mahasiswa.slice(-5).reverse().forEach((mhs, index)=> { %>
                        <tr class="hover:bg-slate-50/50 transition-colors group cursor-pointer"
                            onclick="window.location.href='/mahasiswa'">
                            <td class="py-4 px-6 text-center text-slate-500 font-medium">
                                <%= index + 1 %>
                            </td>
                            <td class="py-4 px-6">
                                <span
                                    class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-slate-100 text-slate-700 border border-slate-200">
                                    <i class="ph ph-identification-card mr-1.5 text-slate-400"></i>
                                    <%= mhs.nim %>
                                </span>
                            </td>
                            <td class="py-4 px-6 font-medium text-slate-800">
                                <%= mhs.nama %>
                            </td>
                        </tr>
                        <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="3" class="py-12 text-center text-slate-500">
                                        <div class="flex flex-col items-center justify-center">
                                            <i class="ph ph-users-three text-4xl mb-3 text-slate-300"></i>
                                            <p>Belum ada data mahasiswa.</p>
                                        </div>
                                    </td>
                                </tr>
                                <% } %>
            </tbody>
        </table>
    </div>
</div>