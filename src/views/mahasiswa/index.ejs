<div class="max-w-6xl mx-auto">
  <!-- Header Section -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <div>
      <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Data Mahasiswa</h2>
      <p class="text-sm text-slate-500 mt-1">Kelola data mahasiswa dengan mudah dan cepat.</p>
    </div>
    <a href="/mahasiswa/create"
      class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl font-medium transition-all shadow-md shadow-indigo-600/20 hover:-translate-y-0.5">
      <i class="ph ph-plus-circle text-xl"></i>
      <span>Tambah Data</span>
    </a>
  </div>

  <!-- Alert Notifikasi -->
  <% if (typeof success !=='undefined' && success) { %>
    <div
      class="mb-6 bg-green-50/80 border border-green-200 text-green-700 px-5 py-3.5 rounded-xl flex items-center gap-3 shadow-sm">
      <i class="ph-fill ph-check-circle text-xl text-green-500"></i>
      <p class="font-medium text-sm">
        <%= success %>
      </p>
    </div>
    <% } %>
      <% if (typeof error !=='undefined' && error) { %>
        <div
          class="mb-6 bg-red-50/80 border border-red-200 text-red-700 px-5 py-3.5 rounded-xl flex items-center gap-3 shadow-sm">
          <i class="ph-fill ph-x-circle text-xl text-red-500"></i>
          <p class="font-medium text-sm">
            <%= error %>
          </p>
        </div>
        <% } %>

          <!-- Table Card -->
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse whitespace-nowrap">
                <thead>
                  <tr class="bg-slate-50/80 border-b border-slate-200 text-slate-500 text-sm">
                    <th class="py-4 px-6 font-semibold w-16 text-center">No</th>
                    <th class="py-4 px-6 font-semibold">NIM</th>
                    <th class="py-4 px-6 font-semibold">Nama Lengkap</th>
                    <th class="py-4 px-6 font-semibold text-center w-56">Aksi</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <% if(mahasiswa && mahasiswa.length> 0) { %>
                    <% mahasiswa.forEach((mhs, index)=> { %>
                      <tr class="hover:bg-slate-50/50 transition-colors group">
                        <td class="py-4 px-6 text-center text-slate-500 font-medium">
                          <%= index + 1 %>
                        </td>
                        <td class="py-4 px-6">
                          <span
                            class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-slate-100 text-slate-700 border border-slate-200">
                            <i class="ph ph-identification-card mr-1.5 text-slate-400"></i>
                            <%= mhs.nim %>
                          </span>
                        </td>
                        <td class="py-4 px-6 font-medium text-slate-800">
                          <%= mhs.nama %>
                        </td>
                        <td class="py-4 px-6">
                          <div class="flex justify-center gap-2 opacity-80 group-hover:opacity-100 transition-opacity">
                            <a href="/mahasiswa/edit/<%= mhs.id %>"
                              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-amber-700 bg-amber-50 hover:bg-amber-100 border border-amber-200 rounded-lg transition-colors">
                              <i class="ph ph-pencil-simple"></i> Edit
                            </a>
                            <a href="/mahasiswa/delete/<%= mhs.id %>"
                              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-red-700 bg-red-50 hover:bg-red-100 border border-red-200 rounded-lg transition-colors"
                              onclick="return confirm('Apakah kamu yakin ingin menghapus data ini?')">
                              <i class="ph ph-trash"></i> Hapus
                            </a>
                          </div>
                        </td>
                      </tr>
                      <% }) %>
                        <% } else { %>
                          <tr>
                            <td colspan="4" class="py-12 text-center text-slate-500">
                              <div class="flex flex-col items-center justify-center">
                                <i class="ph ph-users-three text-4xl mb-3 text-slate-300"></i>
                                <p>Belum ada data mahasiswa.</p>
                              </div>
                            </td>
                          </tr>
                          <% } %>
                </tbody>
              </table>
            </div>
          </div>
</div>