<div class="bg-white p-6 rounded-2xl shadow">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-xl font-bold">Data Mahasiswa</h2>
    <a href="/mahasiswa/create" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">+ Tambah</a>
  </div>

  <% if (success) { %>
    <div class="bg-green-500 text-white px-4 py-3 rounded mb-4">
      <%= success %>
    </div>
  <% } %>

  <table class="w-full text-left border-collapse mt-4">
    <thead>
      <tr class="bg-gray-200">
        <th class="p-3 border-b">No</th>
        <th class="p-3 border-b">Nama</th>
        <th class="p-3 border-b">NIM</th>
        <th class="p-3 border-b">Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% mahasiswa.forEach((m, index) => { %>
        <tr class="hover:bg-gray-50">
          <td class="p-3 border-b"><%= index + 1 %></td>
          <td class="p-3 border-b"><%= m.nama %></td>
          <td class="p-3 border-b"><%= m.nim %></td>
          <td class="p-3 border-b flex gap-2">
            <a href="/mahasiswa/edit/<%= m.id %>" class="bg-yellow-500 text-white px-3 py-1 rounded text-sm">Edit</a>
            <a href="/mahasiswa/delete/<%= m.id %>" onclick="return confirm('Yakin hapus data permanen?')" class="bg-red-500 text-white px-3 py-1 rounded text-sm">Hapus</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>