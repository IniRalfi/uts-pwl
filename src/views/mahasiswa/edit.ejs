<div class="max-w-2xl bg-white p-6 rounded-2xl shadow">
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Edit Mahasiswa</h2>
    <p class="text-gray-500">Perbarui data mahasiswa yang sudah ada</p>
  </div>

  <% if (typeof error !=='undefined' && error) { %>
    <div class="bg-red-100 text-red-700 p-4 rounded-lg mb-4">
      <%= error %>
    </div>
    <% } %>

      <form action="/mahasiswa/update/<%= mhs.id %>" method="POST" class="space-y-4">
        <div>
          <label class="block text-gray-700 mb-2 font-semibold">NIM Mahasiswa</label>
          <input type="text" name="nim" value="<%= mhs.nim %>"
            class="w-full border border-gray-300 px-4 py-2 rounded-lg outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition"
            required>
        </div>

        <div>
          <label class="block text-gray-700 mb-2 font-semibold">Nama Lengkap</label>
          <input type="text" name="nama" value="<%= mhs.nama %>"
            class="w-full border border-gray-300 px-4 py-2 rounded-lg outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition"
            required>
        </div>

        <div class="pt-4 flex space-x-2">
          <button type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-semibold transition">
            Update Data
          </button>
          <a href="/mahasiswa"
            class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg font-semibold transition">
            Batal
          </a>
        </div>
      </form>
</div>