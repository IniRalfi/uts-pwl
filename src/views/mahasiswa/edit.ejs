<div class="max-w-xl mx-auto">
  <!-- Header -->
  <div class="mb-6 flex items-center gap-3">
    <a href="/mahasiswa"
      class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-slate-200 text-slate-500 hover:bg-slate-50 hover:text-indigo-600 transition-colors shadow-sm">
      <i class="ph ph-arrow-left text-xl"></i>
    </a>
    <div>
      <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Edit Mahasiswa</h2>
      <p class="text-sm text-slate-500 mt-0.5">Perbarui data identitas mahasiswa</p>
    </div>
  </div>

  <!-- Form Card -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden relative">
    <!-- Dekorasi aksen atas -->
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-amber-400 to-amber-600"></div>

    <% if (typeof error !=='undefined' && error) { %>
      <div class="bg-red-50/80 border-b border-red-100 text-red-600 px-6 py-4 flex items-center gap-3">
        <i class="ph-fill ph-warning-circle text-xl"></i>
        <p class="text-sm font-medium">
          <%= error %>
        </p>
      </div>
      <% } %>

        <form action="/mahasiswa/update/<%= mhs.id %>" method="POST" class="p-6 sm:p-8 space-y-6">

          <!-- Input NIM -->
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-slate-700">NIM Mahasiswa <span
                class="text-red-500">*</span></label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                <i class="ph ph-identification-card text-lg"></i>
              </div>
              <input type="text" name="nim" value="<%= mhs.nim %>"
                class="w-full pl-11 pr-4 py-2.5 bg-slate-50 border border-slate-200 text-slate-800 rounded-xl outline-none focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 transition-all font-medium"
                required>
            </div>
          </div>

          <!-- Input Nama -->
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-slate-700">Nama Lengkap <span
                class="text-red-500">*</span></label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                <i class="ph ph-user text-lg"></i>
              </div>
              <input type="text" name="nama" value="<%= mhs.nama %>"
                class="w-full pl-11 pr-4 py-2.5 bg-slate-50 border border-slate-200 text-slate-800 rounded-xl outline-none focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 transition-all font-medium"
                required>
            </div>
          </div>

          <hr class="border-slate-100 my-2">

          <!-- Action Buttons -->
          <div class="flex items-center gap-3 pt-2">
            <button type="submit"
              class="flex-1 bg-amber-500 hover:bg-amber-600 text-white px-6 py-2.5 rounded-xl font-medium transition-all shadow-md shadow-amber-500/20 active:scale-[0.98]">
              <div class="flex items-center justify-center gap-2">
                <i class="ph ph-floppy-disk text-lg"></i>
                <span>Update Data</span>
              </div>
            </button>
            <a href="/mahasiswa"
              class="flex-none bg-white border border-slate-200 hover:bg-slate-50 text-slate-600 px-6 py-2.5 rounded-xl font-medium transition-all text-center">
              Batal
            </a>
          </div>

        </form>
  </div>
</div>